    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const inputItem = $input.item.json;\n\n// CENÁRIO 1: Fluxo de Erro (Vindo do Process Error)\nif (inputItem.error) {\n    return $input.item;\n}\n\n// CENÁRIO 2: Fluxo de Sucesso\nconst originalItem = $('Validate & Sanitize').item.json;\n\n// Tenta injetar o ID da OS criada (se existir)\ntry {\n    const osNode = $('Criar OS').last();\n    if (osNode && osNode.json && osNode.json.id) {\n        originalItem.os_criada_id = osNode.json.id;\n        \n        if (originalItem.respostaIA && originalItem.respostaIA.actionData) {\n             originalItem.respostaIA.actionData.os_id_gerado = osNode.json.id;\n        }\n    }\n} catch (e) {}\n\nreturn { json: originalItem };"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1140,
        240
      ],
      "id": "return-context",
      "name": "Retornar Contexto"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// 1. Recupera o contexto original seguro\nconst originalContext = $('Validate & Sanitize').item.json;\n\n// 2. Recupera o erro\nconst errorDetails = $input.item.json; \n\n// 3. Cria resposta de erro\nconst errorResponse = {\n    ...originalContext, \n    error: true,\n    errorDetails: errorDetails\n};\n\n// 4. Sobrescreve mensagem para a IA\nif (errorResponse.respostaIA) {\n    errorResponse.respostaIA.userMessage = \"⚠️ *Erro Técnico*\\n\\nOcorreu uma falha ao registrar a OS de Balcão. Verifique os dados e tente novamente.\";\n    errorResponse.respostaIA.actionData = {};\n}\n\nreturn { json: errorResponse };"
      },
