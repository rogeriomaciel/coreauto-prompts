    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const actionData = $json.respostaIA.actionData;\n\n// Validação Básica\nif (!actionData) throw new Error ('Objeto actionData Inválido');\nif (!actionData.nome_cliente) throw new Error ('Nome do cliente obrigatório');\nif (!actionData.telefone_cliente) throw new Error ('Telefone do cliente obrigatório');\nif (!actionData.placa_veiculo) throw new Error ('Placa obrigatória');\n\n// --- SANITIZAÇÃO ---\n\n// 1. Telefone: Remove tudo que não é número\n// Se não tiver 55 no começo e tiver tamanho de celular BR (11 digitos), adiciona 55\nlet phone = actionData.telefone_cliente.replace(/[^0-9]/g, '');\nif (phone.length === 11) phone = '55' + phone;\nactionData.telefone_cliente = phone;\n\n// 2. Placa: Maiúsculo e sem traços\nactionData.placa_veiculo = actionData.placa_veiculo.replace(/[^a-zA-Z0-9]/g, '').toUpperCase();\n\n// 3. Textos Gerais\nactionData.nome_cliente = actionData.nome_cliente.trim();\nactionData.modelo_veiculo = (actionData.modelo_veiculo || '').toUpperCase().trim();\nactionData.marca_veiculo = (actionData.marca_veiculo || '').toUpperCase().trim();\n\n// Atualiza o JSON\n$input.item.json.respostaIA.actionData = actionData;\n\nreturn $input.item;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -580,
        240
      ],
      "id": "validate-inputs",
      "name": "Validate & Sanitize"
    },
