        "jsCode": "const ad = $json.respostaIA.actionData;\nconst os_id = ad.os_id || $json.pessoa.contexto_memoria.actionDataContext.os_id;\n\nif (!os_id) throw new Error('os_id não encontrado para ATUALIZAR_OS');\n\nreturn {\n  os_id,\n  observacoes_recepcao: ad.observacoes_recepcao || null,\n  orcamento_json: ad.orcamento_parcial || null,\n  observacoes_vistoria: ad.observacoes_vistoria || null,\n  evento_os: ad.evento_os || 'Atualização de informações na OS.'\n};"
      },
