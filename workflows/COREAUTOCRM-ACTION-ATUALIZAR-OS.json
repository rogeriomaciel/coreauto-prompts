      "name": "Preparar Update"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE ordens_servico \nSET \n  observacoes_recepcao = COALESCE($2, observacoes_recepcao),\n  orcamento_json = COALESCE($3, orcamento_json),\n  observacoes_vistoria = COALESCE($4, observacoes_vistoria)\nWHERE id = $1;",
        "options": {
          "queryReplacement": "={{ [$json.os_id, $json.observacoes_recepcao, $json.orcamento_json ? JSON.stringify($json.orcamento_json) : null, $json.observacoes_vistoria] }}"
