      "id": "start-node-id",
      "typeVersion": 1.1,
      "name": "Start",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "position": [
        200,
        200
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const ad = $json.respostaIA.actionData;\nconst os_id = ad.os_id || $json.pessoa.contexto_memoria.actionDataContext.os_id;\n\nif (!os_id) throw new Error('os_id não encontrado para ENVIAR_ORCAMENTO_CLIENTE');\n\nreturn {\n  os_id,\n  orcamento_finalizado: ad.orcamento_finalizado || null,\n  evento_os: ad.evento_os || 'Orçamento finalizado e enviado ao cliente.',\n  notificacao_cliente: ad.notificacao_cliente\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        200
      ],
      "id": "prepare-data-id",
      "name": "Preparar Dados"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT p.whatsapp FROM ordens_servico os JOIN pessoas p ON p.id = os.cliente_id WHERE os.id = $1;",
        "options": {
          "queryReplacement": "={{ [$json.os_id] }}"
        }
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        600,
        200
      ],
      "id": "get-client-phone-id",
      "name": "Buscar WhatsApp do Cliente",
      "credentials": {
        "postgres": {
          "id": "77y5s6MheuLZSCpd",
          "name": "COREAUTOCRM"
        }
      }
    },
    {
      "parameters": {
        "operation": "update",
        "schema": {
          "__rl": true,
          "mode": "list",
          "value": "public"
        },
        "table": {
          "__rl": true,
          "value": "ordens_servico",
          "mode": "list",
          "cachedResultName": "ordens_servico"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "status": "aguardando_aprovacao",
            "orcamento_json": "={{ JSON.stringify($node[\"prepare-data-id\"].json.orcamento_finalizado) }}",
            "id": "={{ $node[\"prepare-data-id\"].json.os_id }}"
          },
          "matchingColumns": [
            "id"
          ],
          "schema": []
        },
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        800,
